+package net.minecraft.src;
+
+import java.io.IOException;
+import java.util.concurrent.LinkedBlockingQueue;
+import java.util.concurrent.TimeUnit;
+
+public class ChunkSaveQueue implements Runnable {
+	private static final LinkedBlockingQueue<SaveTask> queue = new LinkedBlockingQueue<>();
+	private static volatile boolean running = true;
+
+	private static class SaveTask {
+		World world;
+		Chunk chunk;
+		IChunkLoader loader;
+
+		SaveTask(World w, Chunk c, IChunkLoader l) {
+			this.world = w;
+			this.chunk = c;
+			this.loader = l;
+		}
+	}
+
+	public static void queueChunkSave(World world, Chunk chunk, IChunkLoader loader) {
+		chunk.lastSaveTime = world.getWorldTime();
+
+		queue.add(new SaveTask(world, chunk, loader));
+	}
+
+	public static void finishAndStop() {
+		running = false;
+		while (!queue.isEmpty()) {
+			try {
+				Thread.sleep(100L); // 残りがある間は待機
+			} catch (InterruptedException e) {}
+		}
+	}
+
+	@Override
+	public void run() {
+		while (running || !queue.isEmpty()) {
+			try {
+				SaveTask task = queue.poll(500, TimeUnit.MILLISECONDS);
+
+				if (task != null && task.loader != null) {
+					task.loader.saveChunk(task.world, task.chunk);
+				}
+			} catch (IOException e) {
+				System.err.println("Failed to save chunk asynchronously!");
+				e.printStackTrace();
+			} catch (InterruptedException e) {
+			}
+		}
+		System.out.println("Chunk Save Thread stopped safely.");
+	}
+}
